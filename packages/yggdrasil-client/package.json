{
  "name": "@loontail/yggdrasil-client",
  "version": "0.0.1",
  "description": "TypeScript HTTP client for Yggdrasil-compatible auth servers, bundled with the authlib-injector jar and a -javaagent argument builder.",
  "license": "MIT",
  "author": {
    "name": "Loontail",
    "email": "estluced@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/loontail/loontail-yggdrasil.git",
    "directory": "packages/yggdrasil-client"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": ["dist", "vendor"],
  "sideEffects": false,
  "scripts": {
    "fetch-authlib-injector": "node scripts/fetch-authlib-injector.mjs",
    "prebuild": "npm run fetch-authlib-injector",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check ."
  },
  "dependencies": {
    "@loontail/yggdrasil-core": "^0.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
