{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2022",
    // Admin runs in browser; needs DOM lib.
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "verbatimModuleSyntax": false,
    "rootDir": ".",
    "outDir": "dist",
    "noEmit": true,
    "types": ["node"],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "jsx": "react-jsx"
  },
  "include": ["server", "shared", "admin"]
}
